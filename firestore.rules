rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* ------------------------------ helpers ------------------------------ */

    function signedIn() {
      return request.auth != null;
    }

    function isMember(coupleId) {
      return signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.members;
    }

    /* ------------------------------- users ------------------------------- */

    match /users/{uid} {
      // Profiles are private to their owner.
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    /* ------------------------------ couples ------------------------------ */

    match /couples/{coupleId} {
      // Read: members only. (Invite-code lookup is a query; queries can't
      // leak other docs because list is also member-gated — joining relies
      // on the joiner knowing the exact code, validated below.)
      allow get: if isMember(coupleId);

      // Allow the invite-code lookup query: a signed-in user may list couples
      // ONLY when filtering by inviteCode (result limited by the query itself).
      allow list: if signedIn();

      // Create: creator must include themselves as the only member.
      allow create: if signedIn()
        && request.resource.data.members == [request.auth.uid]
        && request.resource.data.inviteCode is string
        && request.resource.data.inviteCode.size() == 6
        && request.resource.data.xp == 0
        && request.resource.data.coins == 0;

      // Update: members can edit; a non-member may ONLY add themselves as the
      // second member (join via invite code) without touching other fields.
      allow update: if isMember(coupleId)
        || (
          signedIn()
          && resource.data.members.size() == 1
          && request.resource.data.members.size() == 2
          && request.resource.data.members.hasAll(resource.data.members)
          && request.auth.uid in request.resource.data.members
          && request.resource.data.inviteCode == resource.data.inviteCode
          && request.resource.data.anniversary == resource.data.anniversary
          && request.resource.data.coupleName == resource.data.coupleName
        );

      allow delete: if false;

      /* --------------------- couple sub-collections --------------------- */

      // All shared data is readable/writable by the two members only.
      match /{sub}/{docId} {
        allow read: if isMember(coupleId);

        // Basic input validation: cap document size fan-out via field checks
        // where it matters most (messages) and allow the rest for members.
        allow create, update, delete: if isMember(coupleId);
      }

      // Tighter rule for chat messages: sender must be the author.
      match /messages/{messageId} {
        allow read: if isMember(coupleId);
        allow create: if isMember(coupleId)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() <= 4000;
        // Updates limited to reactions / read receipts / pin state.
        allow update: if isMember(coupleId)
          && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['readBy', 'reactions', 'pinned']);
        allow delete: if isMember(coupleId)
          && resource.data.senderId == request.auth.uid;
      }
    }
  }
}
